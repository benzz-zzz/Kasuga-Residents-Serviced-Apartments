# =============================================================================
# Environment variables — tanan gibasa sa config.php gikan sa .env (Dotenv)
# o gikan sa Railway / shell environment.
# Copy to ".env" sa project root. Ang value nga dunay space: butangi og double quotes, e.g.
#   APP_NAME="Kasuga Residences"
# Dili i-commit ang .env nga dunay tinuod nga secrets.
#
# Railway: ang parehas nga KEY i-set sa imong web service → Variables → RAW editor (i-paste ang
# mga active line gikan sa imong local .env). I-reference ang MySQL plugin (MYSQL_URL / MYSQL*).
# Ang railway.toml dili makastore og secret values — design sa Railway mismo.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# APP_NAME=Kasuga Residences
# APP_TIMEZONE=Asia/Manila
# APP_BASE=
# APP_PUBLIC_URL=https://your-service.up.railway.app

# -----------------------------------------------------------------------------
# Database (o i-reference ang MYSQL_* gikan sa Railway MySQL plugin)
# -----------------------------------------------------------------------------
# MYSQL_URL=mysql://user:pass@host:3306/railway
# MYSQLHOST=
# MYSQLPORT=3306
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=

# DB_CHARSET=utf8mb4
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=kasuga_residences
# DB_USER=root
# DB_PASS=

# -----------------------------------------------------------------------------
# Railway (auto-injected; dokumentasyon ra)
# -----------------------------------------------------------------------------
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PUBLIC_DOMAIN=

# -----------------------------------------------------------------------------
# Property / map
# -----------------------------------------------------------------------------
# PROPERTY_NAME=Kasuga Residences
# PROPERTY_ADDRESS=
# PROPERTY_LAT=14.5995
# PROPERTY_LNG=120.9842
# PROPERTY_MAP_ZOOM=13

# -----------------------------------------------------------------------------
# Room gallery
# -----------------------------------------------------------------------------
# ROOM_GALLERY_MAX_IMAGES=6
# ROOM_GALLERY_PUBLIC_MAX=3

# -----------------------------------------------------------------------------
# Mail
# -----------------------------------------------------------------------------
# MAIL_FROM=noreply@example.com
# MAIL_FROM_NAME=Kasuga Residences
# MAIL_SMTP_HOST=smtp.gmail.com
# MAIL_SMTP_PORT=587
# MAIL_SMTP_ENCRYPTION=tls
# MAIL_SMTP_USER=
# MAIL_SMTP_PASS=

# -----------------------------------------------------------------------------
# CAPTCHA (reCAPTCHA v2 Checkbox: https://www.google.com/recaptcha/admin )
# Kon duha ka RECAPTCHA_* naa’y sulod, Google gamiton; Turnstile optional.
# -----------------------------------------------------------------------------
# RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# CAPTCHA_BYPASS_LOCAL=0

# -----------------------------------------------------------------------------
# Nixpacks (Railway build; dili gibasa sa config.php)
# -----------------------------------------------------------------------------
# NIXPACKS_PHP_VERSION=8.2
